    "typecheck": "tsc --noEmit",
    "test": "bun run appraisal.test.js"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "happy-dom": "^20.10.6",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "postgres": "^3.4.9"
  }
}
